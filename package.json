{
  "name": "@dreki-gg/pi-code-reviewer",
  "version": "0.9.0",
  "description": "Multi-lens code review extension for pi \u2014 configurable review criteria per project",
  "keywords": [
    "pi-package"
  ],
  "author": "Juan Albarran <jalbarrandev@gmail.com>",
  "license": "MIT",
  "files": [
    "extensions",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jalbarrang/pi-code-reviewer.git"
  },
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "oxlint extensions test",
    "format": "oxfmt --write extensions test",
    "format:check": "oxfmt --check extensions test"
  },
  "pi": {
    "extensions": [
      "./extensions/code-reviewer"
    ],
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@types/node": "24",
    "bun-types": "latest",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.0",
    "@earendil-works/pi-ai": "^0.75.4",
    "@earendil-works/pi-coding-agent": "^0.75.4",
    "@earendil-works/pi-tui": "^0.75.4",
    "typebox": "^1.0.55"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  }
}
