{
  "name": "@dreki-gg/pi-code-reviewer",
  "version": "0.10.0",
  "description": "Multi-lens code review extension for pi — configurable review criteria per project",
  "keywords": [
    "pi-package"
  ],
  "author": "Juan Albarran <jalbarrandev@gmail.com>",
  "license": "MIT",
  "files": [
    "extensions",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jalbarrang/pi-code-reviewer.git"
  },
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "oxlint extensions test",
    "format": "oxfmt --write extensions test",
    "format:check": "oxfmt --check extensions test",
    "sync:canonical": "node scripts/sync-canonical.mjs"
  },
  "pi": {
    "extensions": [
      "./extensions/code-reviewer"
    ],
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "effect": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "26",
    "bun-types": "latest",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "typescript": "^7.0.2",
    "@earendil-works/pi-ai": "^0.82.0",
    "@earendil-works/pi-coding-agent": "^0.82.0",
    "@earendil-works/pi-tui": "^0.82.0",
    "typebox": "^1.3.7"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.80.0",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
